# Claire Observability — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# Token d'authentification API (obligatoire — à changer en prod)
CLAIRE_API_TOKEN=changeme

# Chemin SQLite — sur Railway, pointer vers le volume monté
# Local  : ./claire.db  (défaut)
# Railway: /data/claire.db
CLAIRE_DB_PATH=./claire.db

# Alertes Slack (optionnel)
# CLAIRE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Alertes email (optionnel)
# CLAIRE_ALERT_EMAIL_RECIPIENT=admin@tondomaine.com
